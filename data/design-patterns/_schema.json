{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bricks-mcp.local/schemas/design-pattern-file.json",
  "title": "Design pattern file",
  "description": "Shape of a category pattern file in data/design-patterns/ (e.g. heroes.json, features.json).",
  "type": "object",
  "required": ["category", "patterns"],
  "additionalProperties": true,
  "properties": {
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Category ID from the dynamic category registry (no longer a fixed enum)"
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pattern" }
    }
  },
  "$defs": {
    "pattern": {
      "type": "object",
      "required": ["id", "name", "tags", "layout"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layout": {
          "type": "string",
          "enum": ["centered", "split-60-40", "split-50-50", "split-40-60", "grid-2", "grid-3", "grid-4", "stacked"]
        },
        "background": {
          "type": "string",
          "enum": ["light", "dark"]
        },
        "background_image": { "type": "boolean" },
        "ai_description": { "type": "string", "maxLength": 300 },
        "ai_usage_hints": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "source": {
          "type": "string",
          "enum": ["plugin", "user_file", "database"]
        },
        "section_overrides": { "type": "object", "additionalProperties": true },
        "container_overrides": { "type": "object", "additionalProperties": true },
        "gradient_overlay": { "type": "object", "additionalProperties": true },
        "has_two_rows": { "type": "boolean" },
        "rows": {
          "type": "object",
          "additionalProperties": true
        },
        "columns": {
          "type": "object",
          "additionalProperties": true
        },
        "composition": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "patterns": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
