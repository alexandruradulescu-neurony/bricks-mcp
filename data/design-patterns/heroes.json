{
  "category": "hero",
  "patterns": [
    {
      "id": "hero-centered-dark",
      "name": "Centered Dark Hero",
      "description": "Full-height dark hero with centered text stack and CTA buttons. Classic homepage hero.",
      "tags": [
        "dark",
        "centered",
        "cta",
        "homepage"
      ],
      "layout": "centered",
      "background": "dark",
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "container_overrides": {
        "_alignItems": "center",
        "_textAlign": "center"
      },
      "composition": [
        {
          "role": "eyebrow",
          "type": "text-basic",
          "class_role": "eyebrow",
          "content_example": "— TRACTARI AUTO NON-STOP"
        },
        {
          "role": "heading",
          "type": "heading",
          "tag": "h1",
          "content_example": "Tractari Auto Bucuresti & Ilfov. Rapid. Corect. <span style=\"color:var(--secondary)\">Fara surprize.</span>"
        },
        {
          "role": "subtitle",
          "type": "text-basic",
          "class_role": "hero_description",
          "content_example": "Ajungem la tine in maximum 30 de minute. Pretul comunicat la telefon este pretul final — cu TVA inclus."
        },
        {
          "role": "cta_row",
          "wrapper": true,
          "wrapper_style": {
            "_direction": "row",
            "_gap": "var(--space-m)",
            "_justifyContent": "center",
            "_flexWrap": "wrap"
          },
          "elements": [
            {
              "role": "primary_cta",
              "type": "button",
              "class_role": "btn_primary",
              "icon": "mobile",
              "iconPosition": "left",
              "content_example": "Suna Acum: 0722 222 222"
            },
            {
              "role": "secondary_cta",
              "type": "button",
              "class_role": "btn_ghost",
              "icon": "comment-alt",
              "iconPosition": "left",
              "content_example": "WhatsApp"
            }
          ]
        }
      ],
      "ai_description": "Full-height dark hero with centered eyebrow, H1, subtitle, and 2 CTA buttons. Classic bold homepage opener.",
      "ai_usage_hints": [
        "Best as first section on homepage or landing pages",
        "Pair with features section below",
        "Replace eyebrow with site-specific tagline"
      ]
    },
