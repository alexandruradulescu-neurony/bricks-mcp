    {
      "id": "hero-split-cards",
      "name": "Split Hero with Stat Cards",
      "description": "60/40 split. Left: text stack with CTAs. Right: stacked glass stat cards with icons.",
      "tags": [
        "dark",
        "split",
        "cards",
        "stats",
        "homepage"
      ],
      "layout": "split-60-40",
      "background": "dark",
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "columns": {
        "left": {
          "gap": "var(--space-l)",
          "elements": [
            {
              "role": "eyebrow",
              "type": "text-basic",
              "class_role": "eyebrow"
            },
            {
              "role": "heading",
              "type": "heading",
              "tag": "h1"
            },
            {
              "role": "subtitle",
              "type": "text-basic",
              "class_role": "hero_description"
            },
            {
              "role": "cta_row",
              "wrapper": true,
              "wrapper_style": {
                "_direction": "row",
                "_gap": "var(--space-m)",
                "_flexWrap": "wrap"
              },
              "elements": [
                {
                  "role": "primary_cta",
                  "type": "button",
                  "class_role": "btn_primary",
                  "icon": "mobile",
                  "iconPosition": "left"
                },
                {
                  "role": "secondary_cta",
                  "type": "button",
                  "class_role": "btn_ghost",
                  "icon": "comment-alt",
                  "iconPosition": "left"
                }
              ]
            }
          ]
        },
        "right": {
          "elements": [
            {
              "role": "stat_cards",
              "type": "pattern",
              "pattern_name": "stat-card",
              "repeat": 4
            }
          ]
        }
      },
      "patterns": {
        "stat-card": {
          "class_role": "stat_card",
          "wrapper_style": {
            "_direction": "row",
            "_alignItems": "center",
            "_gap": "var(--space-m)"
          },
          "elements": [
            {
              "role": "card_icon_circle",
              "type": "block",
              "style": {
                "_width": "48px",
                "_height": "48px",
                "_minWidth": "48px",
                "_alignItems": "center",
                "_justifyContent": "center",
                "_border": {
                  "radius": {
                    "top": "var(--radius-m)",
                    "right": "var(--radius-m)",
                    "bottom": "var(--radius-m)",
                    "left": "var(--radius-m)"
                  }
                },
                "_background": {
                  "color": {
                    "raw": "data.icon_bg"
                  }
                }
              },
              "children": [
                {
                  "role": "card_icon",
                  "type": "icon",
                  "icon": "data.icon"
                }
              ]
            },
            {
              "role": "card_text",
              "type": "block",
              "children": [
                {
                  "role": "card_title",
                  "type": "heading",
                  "tag": "h4"
                },
                {
                  "role": "card_desc",
                  "type": "text-basic"
                }
              ]
            }
          ]
        }
      },
      "ai_description": "60/40 split dark hero. Left: eyebrow + H1 + subtitle + 2 CTAs. Right: stacked glass stat cards with icons showing key metrics.",
      "ai_usage_hints": [
        "Best for data-driven companies showing trust metrics",
        "Right-side cards work with 3-4 stat items",
        "Pair with testimonials below for social proof"
      ]
    },
