{
  "category": "hero",
  "patterns": [
    {
      "id": "hero-centered-dark",
      "name": "Centered Dark Hero",
      "description": "Full-height dark hero with centered text stack and CTA buttons. Classic homepage hero.",
      "tags": ["dark", "centered", "cta", "homepage"],
      "layout": "centered",
      "background": "dark",
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "container_overrides": {
        "_alignItems": "center",
        "_textAlign": "center"
      },
      "composition": [
        {"role": "eyebrow", "type": "text-basic", "class_role": "eyebrow", "content_example": "— TRACTARI AUTO NON-STOP"},
        {"role": "heading", "type": "heading", "tag": "h1", "content_example": "Tractari Auto Bucuresti & Ilfov. Rapid. Corect. <span style=\"color:var(--secondary)\">Fara surprize.</span>"},
        {"role": "subtitle", "type": "text-basic", "class_role": "hero_description", "content_example": "Ajungem la tine in maximum 30 de minute. Pretul comunicat la telefon este pretul final — cu TVA inclus."},
        {"role": "cta_row", "wrapper": true, "wrapper_style": {"_direction": "row", "_gap": "var(--space-m)", "_justifyContent": "center", "_flexWrap": "wrap"}, "elements": [
          {"role": "primary_cta", "type": "button", "class_role": "btn_primary", "icon": "mobile", "iconPosition": "left", "content_example": "Suna Acum: 0722 222 222"},
          {"role": "secondary_cta", "type": "button", "class_role": "btn_ghost", "icon": "comment-alt", "iconPosition": "left", "content_example": "WhatsApp"}
        ]}
      ]
    },
    {
      "id": "hero-centered-dark-image",
      "name": "Centered Dark Hero with Background Image",
      "description": "Same as centered dark hero but with a background photo and gradient overlay.",
      "tags": ["dark", "centered", "cta", "homepage", "image", "overlay"],
      "layout": "centered",
      "background": "dark",
      "background_image": true,
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "container_overrides": {
        "_alignItems": "center",
        "_textAlign": "center"
      },
      "gradient_overlay": {
        "colors": [
          {"color": {"raw": "rgba(46, 46, 61, 0.8)"}, "stop": "0"},
          {"color": {"raw": "rgba(142, 47, 34, 0.6)"}, "stop": "100"}
        ],
        "applyTo": "overlay"
      },
      "composition": [
        {"role": "eyebrow", "type": "text-basic", "class_role": "eyebrow"},
        {"role": "heading", "type": "heading", "tag": "h1"},
        {"role": "subtitle", "type": "text-basic", "class_role": "hero_description"},
        {"role": "cta_row", "wrapper": true, "wrapper_style": {"_direction": "row", "_gap": "var(--space-m)", "_justifyContent": "center", "_flexWrap": "wrap"}, "elements": [
          {"role": "primary_cta", "type": "button", "class_role": "btn_primary", "icon": "mobile", "iconPosition": "left"},
          {"role": "secondary_cta", "type": "button", "class_role": "btn_ghost", "icon": "comment-alt", "iconPosition": "left"}
        ]}
      ]
    },
    {
      "id": "hero-split-cards",
      "name": "Split Hero with Stat Cards",
      "description": "60/40 split. Left: text stack with CTAs. Right: stacked glass stat cards with icons.",
      "tags": ["dark", "split", "cards", "stats", "homepage"],
      "layout": "split-60-40",
      "background": "dark",
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "columns": {
        "left": {
          "elements": [
            {"role": "eyebrow", "type": "text-basic", "class_role": "eyebrow"},
            {"role": "heading", "type": "heading", "tag": "h1"},
            {"role": "subtitle", "type": "text-basic", "class_role": "hero_description"},
            {"role": "cta_row", "wrapper": true, "wrapper_style": {"_direction": "row", "_gap": "var(--space-m)", "_flexWrap": "wrap"}, "elements": [
              {"role": "primary_cta", "type": "button", "class_role": "btn_primary", "icon": "mobile", "iconPosition": "left"},
              {"role": "secondary_cta", "type": "button", "class_role": "btn_ghost", "icon": "comment-alt", "iconPosition": "left"}
            ]}
          ]
        },
        "right": {
          "elements": [
            {"role": "stat_cards", "type": "pattern", "pattern_name": "stat-card", "repeat": 4}
          ]
        }
      },
      "patterns": {
        "stat-card": {
          "class_role": "stat_card",
          "wrapper_style": {"_direction": "row", "_alignItems": "center", "_gap": "var(--space-m)"},
          "elements": [
            {"role": "card_icon_circle", "type": "block", "style": {"_width": "48px", "_height": "48px", "_minWidth": "48px", "_alignItems": "center", "_justifyContent": "center", "_border": {"radius": {"top": "var(--radius-m)", "right": "var(--radius-m)", "bottom": "var(--radius-m)", "left": "var(--radius-m)"}}, "_background": {"color": {"raw": "data.icon_bg"}}}, "children": [
              {"role": "card_icon", "type": "icon", "icon": "data.icon"}
            ]},
            {"role": "card_text", "type": "block", "children": [
              {"role": "card_title", "type": "heading", "tag": "h4"},
              {"role": "card_desc", "type": "text-basic"}
            ]}
          ]
        }
      }
    },
    {
      "id": "hero-split-image",
      "name": "Split Hero with Image",
      "description": "50/50 split. Left: text stack. Right: large rounded image.",
      "tags": ["dark", "split", "image", "homepage"],
      "layout": "split-50-50",
      "background": "dark",
      "section_overrides": {
        "_minHeight": "80vh",
        "_justifyContent": "center"
      },
      "columns": {
        "left": {
          "elements": [
            {"role": "eyebrow", "type": "text-basic", "class_role": "eyebrow"},
            {"role": "heading", "type": "heading", "tag": "h1"},
            {"role": "subtitle", "type": "text-basic", "class_role": "hero_description"},
            {"role": "cta_row", "wrapper": true, "wrapper_style": {"_direction": "row", "_gap": "var(--space-m)", "_flexWrap": "wrap"}, "elements": [
              {"role": "primary_cta", "type": "button", "class_role": "btn_primary"},
              {"role": "secondary_cta", "type": "button", "class_role": "btn_ghost"}
            ]}
          ]
        },
        "right": {
          "fill": true,
          "elements": [
            {"role": "hero_image", "type": "image", "style": {"_border": {"radius": {"top": "var(--radius-l)", "right": "var(--radius-l)", "bottom": "var(--radius-l)", "left": "var(--radius-l)"}}, "_objectFit": "cover", "_height": "100%"}}
          ]
        }
      }
    }
  ]
}
