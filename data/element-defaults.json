{
  "_comment": "Default settings per element type. Used by ElementSettingsGenerator to produce valid Bricks elements from design schemas. Content keys map schema 'content' to the correct Bricks settings key.",
  "content_keys": {
    "heading": "text",
    "text-basic": "text",
    "text": "text",
    "text-link": "text",
    "button": "text",
    "icon-box": "content",
    "alert": "content",
    "counter": "countTo",
    "animated-typing": "prefix",
    "video": "iframeUrl",
    "pricing-tables": "pricingTables",
    "testimonials": "items",
    "social-icons": "icons",
    "progress-bar": "bars",
    "rating": "rating",
    "pie-chart": "percent"
  },
  "default_tags": {
    "heading": "h2",
    "text": "p",
    "text-basic": "p"
  },
  "structural_elements": ["section", "container", "block", "div"],
  "flex_by_default": ["section", "container", "block"],
  "nestable_variants": {
    "tabs": "tabs-nested",
    "accordion": "accordion-nested",
    "nav": "nav-nested"
  },
  "skip_auto_flex": ["tabs-nested", "accordion-nested", "nav-nested", "slider-nested"],
  "icon_defaults": {
    "library": "themify",
    "prefix": "ti-",
    "fallback": "ti-star"
  },
  "button_defaults": {
    "style": "primary",
    "link": { "type": "external", "url": "#" }
  },
  "element_settings_defaults": {
    "counter":         { "countTo": 100, "duration": 2000 },
    "pie-chart":       { "percent": 75, "size": 200, "lineWidth": 16 },
    "progress-bar":    { "bars": [ { "label": "Progress", "percentage": 75 } ] },
    "rating":          { "rating": 5, "maxRating": 5 },
    "animated-typing": { "strings": [ "Loading..." ], "typeSpeed": 80 }
  },
  "form_templates": {
    "newsletter": {
      "fields": [
        {"id": "nl_001", "type": "email", "label": "Email", "placeholder": "Adresa ta de email", "required": true, "width": "calc(67% - var(--space-xs)/2)"},
        {"id": "nl_002", "type": "html", "label": "Termeni", "width": "100", "html": "<p style=\"margin-top:var(--space-xs);font-size:var(--text-xs)\">Prin inregistrare, accepti <a href=\"#\">Termenii si Conditiile</a> noastre.</p>"}
      ],
      "actions": ["email"],
      "submitButtonStyle": "primary",
      "submitButtonText": "Inregistrare",
      "submitButtonWidth": "calc(33% - var(--space-xs)/2)",
      "horizontalAlignFields": "space-between",
      "successMessage": "Te-ai inregistrat cu succes!",
      "emailSubject": "Inregistrare noua",
      "emailTo": "admin_email",
      "htmlEmail": true
    },
    "contact": {
      "fields": [
        {"id": "ct_001", "type": "text", "label": "Nume", "placeholder": "Numele tau", "width": "50"},
        {"id": "ct_002", "type": "email", "label": "Email", "placeholder": "Email-ul tau", "required": true, "width": "50"},
        {"id": "ct_003", "type": "textarea", "label": "Mesaj", "placeholder": "Mesajul tau", "required": true, "width": "100"}
      ],
      "actions": ["email"],
      "submitButtonStyle": "primary",
      "submitButtonText": "Trimite mesajul",
      "successMessage": "Mesajul a fost trimis cu succes. Te vom contacta in cel mai scurt timp.",
      "emailSubject": "Mesaj nou de pe site",
      "emailTo": "admin_email",
      "htmlEmail": true
    },
    "login": {
      "fields": [
        {"id": "lg_001", "type": "email", "label": "Email sau nume utilizator", "placeholder": "Email sau nume utilizator", "required": true, "width": "100"},
        {"id": "lg_002", "type": "password", "label": "Parola", "placeholder": "Parola ta", "required": true, "width": "100"}
      ],
      "actions": ["email"],
      "submitButtonStyle": "primary",
      "submitButtonText": "Conectare",
      "successMessage": "Conectare reusita.",
      "emailSubject": "Tentativa de conectare",
      "emailTo": "admin_email",
      "htmlEmail": true
    }
  }
}
